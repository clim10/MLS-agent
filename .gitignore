# Ignore everything by default
/*

# Always keep git metadata
!.gitignore
!.gitattributes
!.editorconfig
!README.md
!LICENSE
!CODEOWNERS

# Allow these directories
!/.vscode/
!/agents/
!/instructions/
!/skills/

# Allow files inside the allowed directories
!.vscode/**
!/agents/**
!/instructions/**
!/skills/**

# (Optional) explicitly ignore these, for clarity
/ide/
/logs/
/pkg/
/session-state/
command-history-state.json
config.json